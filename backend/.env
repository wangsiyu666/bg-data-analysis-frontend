# ============================================
# TeleCompass 后端环境变量配置
# ============================================

# ---------- PostgreSQL 配置 ----------
# 用于存储策略库、产品库等业务数据
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=telecompass

# ---------- ClickHouse 配置 ----------
# 用于存储用户行为数据、流量日志等分析数据
CLICKHOUSE_HOST=host.docker.internal
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ---------- Redis 配置 ----------
# 用于 Celery 消息代理和结果存储
REDIS_URL=redis://host.docker.internal:6379/0

# ---------- Ollama 配置 ----------
# 大模型服务地址（Ollama 运行在宿主机，使用http://host.docker.internal）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# 使用的模型名称（需提前在 Ollama 中下载）
LLM_MODEL=qwen:7b-chat-q4_0

# ---------- 应用配置 ----------
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
DEBUG=true

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000