DROP TABLE IF EXISTS user_behavior;

CREATE TABLE user_behavior (
    month String COMMENT '数据统计的月份',
    user_id String COMMENT '系统内唯一标识用户的编号',
    city_id String COMMENT '用户号码归属的地市级行政区域',
    age Int32 COMMENT '用户的实际年龄',
    sex_id String COMMENT '用户的性别信息',
    prv1_userstatus_id String COMMENT '用户上个月的状态（如正常、停机、预销户等）',
    star_level String COMMENT '用户星级：根据用户消费能力、信用度、在网时长等综合因素评定的用户等级',
    star_level_b Int8 COMMENT '对比当前月与上月用户星级是否发生变化',
    is_jxhm Int8 COMMENT '判断用户号码是否属于吉祥号',
    brand_id Int8 COMMENT '动感地带为1，神州行为2、全球通为3，其他为4',
    user_online Int32 COMMENT '用户从入网到当前时间的累计在网时长',
    arpu120_user Int8 COMMENT '根据当月ARPU值是否达到一定阈值（如120元）来判断是否为中高端客户',
    bd_arpu120_user Int8 COMMENT '对比当前月与上月中高端客户标识是否发生变化',
    credit_id String COMMENT '根据用户的缴费记录、欠费情况等评估的信用等级',
    credit_id_b Int8 COMMENT '对比当前月与上月用户信用度等级是否发生变化',
    paytype21_user Int8 COMMENT '判断用户是否通过代付或托收方式支付费用',
    is_acct_counts Int8 COMMENT '判断用户是否与其他用户合并账单',
    is_rhtc Int8 COMMENT '判断用户是否使用包含语音、流量、宽带等多业务的融合套餐',
    qx_rhtc_3month Int8 COMMENT '近三月存在"是否融合套餐用户"=0 and 三月前月表"是否融合套餐用户"=1',
    xz_rhtc_3month Int8 COMMENT '近三月存在"是否融合套餐用户"=1 and 三月前月表"是否融合套餐用户"=0',
    is_jttf Int8 COMMENT '判断用户是否属于集团统付或代付用户',
    qx_jttf_3month Int8 COMMENT '近三个月内是否存在"是否集团统付/代付"从1变为0的情况',
    regiontype_id3 Int8 COMMENT '根据用户归属地判断是否为农村用户',
    student_flag Int8 COMMENT '判断用户是否为学生身份',
    month_new_mark Int8 COMMENT '判断用户是否为当月新入网用户',
    month_new_mark_6month Int8 COMMENT '判断用户是否为近6个月内新入网用户',
    zero_mark Int8 COMMENT '判断用户当月是否无任何通信行为（如通话、流量使用等）',
    arpu_fluctuate_mark Int8 COMMENT '用户消费金额波动较大，通常指ARPU值波动率超过一定阈值',
    arpu_stabilize_mark Int8 COMMENT '用户消费金额较为稳定，通常指ARPU值波动率低于一定阈值',
    active_mark Int8 COMMENT '判断用户当月是否有通信行为（如通话、短信、流量使用等）',
    dou_mark Int8 COMMENT '判断用户当月是否有流量使用行为',
    is_ll_dh Int8 COMMENT '是否通话用户=0 and dou>1G',
    is_yy_dh Int8 COMMENT '主叫通话次数>1 and dou<50M',
    is_dh_2month Int8 COMMENT '连续2月是否流量单活用户 or 是否语音单活用户',
    is_dh_3month Int8 COMMENT '连续3月是否流量单活用户 or 是否语音单活用户',
    vip_mark Int8 COMMENT '判断用户是否为企业或集团大客户',
    ys_yd_yh Int8 COMMENT '根据用户行为异常（如突然停机、大量投诉等）判断是否为疑似异动用户',
    mon_consume_id String COMMENT '根据用户月消费金额划分的消费层次（如低、中、高）',
    call_mark Int8 COMMENT '判断用户当月是否有通话行为',
    school_flag Int8 COMMENT '判断用户归属地是否为校园区域',
    family_main Int8 COMMENT '判断用户是否为亲情网主卡用户',
    is_family Int8 COMMENT '判断用户当月是否为亲情网用户',
    qx_family_3month Int8 COMMENT '近三个月内是否存在取消亲情网的情况',
    owe_fee Decimal(18,2) COMMENT '用户月末的欠费金额',
    owe_fee_pre1 Decimal(18,2) COMMENT '用户上月末的欠费金额',
    owe_fee_pre2 Decimal(18,2) COMMENT '用户上上月末的欠费金额',
    zs_fee Decimal(18,2) COMMENT '用户当月获得的赠送费用金额',
    zs_fee_v Decimal(10,4) COMMENT '赠送费用占当月出账收入的比例',
    zs_fee_time Date COMMENT '赠送费用的有效期截止时间',
    PAY_FEE Decimal(18,2) COMMENT '用户当月的缴费金额',
    PAY_FEE_pre1 Decimal(18,2) COMMENT '用户上月的缴费金额',
    PAY_FEE_pre2 Decimal(18,2) COMMENT '用户上上月的缴费金额',
    PAY_FEE_v Decimal(10,4) COMMENT '当月缴费金额与上月相比的增长比例',
    pay_counts Int32 COMMENT '用户当月的缴费次数',
    pay_counts_pre1 Int32 COMMENT '用户上月的缴费次数',
    pay_counts_pre2 Int32 COMMENT '用户上上月的缴费次数',
    pay_counts_v Decimal(10,4) COMMENT '当月缴费次数与上月相比的增长比例',
    pay_counts_3month Int32 COMMENT '用户近三个月的累计缴费次数',
    pay_fee_3month Decimal(18,2) COMMENT '用户近三个月的累计缴费金额',
    pve_amount Decimal(18,2) COMMENT '用户当月账户余额',
    pve1_amount Decimal(18,2) COMMENT '用户上月账户余额',
    pve2_amount Decimal(18,2) COMMENT '用户上上月账户余额',
    prepay_bal Decimal(18,2) COMMENT '用户当月月末的账户余额',
    prepay_bal_v Decimal(10,4) COMMENT '当月月末账户余额与上月相比的增长比例',
    amount_bd Decimal(10,4) COMMENT '用户账户余额的波动情况，通常用标准差计算',
    credit Decimal(18,2) COMMENT '用户当月的透支额度',
    credit_pve1 Decimal(18,2) COMMENT '用户上月的透支额度',
    credit_pve2 Decimal(18,2) COMMENT '用户上上月的透支额度',
    arpu Decimal(10,2) COMMENT '每用户平均收入，计算公式为总收入/用户数',
    arpu_pve1 Decimal(10,2) COMMENT '上月的每用户平均收入',
    arpu_pve2 Decimal(10,2) COMMENT '上上月的每用户平均收入',
    avg_3mon_fee Decimal(10,2) COMMENT '近三个月的每用户平均收入均值',
    arpu_bd Decimal(10,4) COMMENT '近三个月ARPU值的波动情况，通常用标准差计算',
    arpu_pve1_v Decimal(10,4) COMMENT '当月出账收入与上月相比的下降比例',
    avg_gprsplan_fee_3m Decimal(10,2) COMMENT '近三个月GPRS套餐费用的平均值',
    newbusi_fee Decimal(18,2) COMMENT '用户当月新业务（如增值业务）的费用',
    newbusi_fee1 Decimal(18,2) COMMENT '用户上月新业务的费用',
    newbusi_fee_v Decimal(10,4) COMMENT '新业务费用与上月相比的变化情况',
    LAM_YZF_FEE Decimal(18,2) COMMENT '用户当月的月租费用',
    LAM_YZF_FEE_v Decimal(10,4) COMMENT '当月月租费用与上月相比的增长比例',
    LAM_YZF_FEE_pre1 Decimal(18,2) COMMENT '用户上月的月租费用',
    LAM_YZF_FEE_pre2 Decimal(18,2) COMMENT '用户上上月的月租费用',
    call_fee Decimal(18,2) COMMENT '用户当月的通话费用',
    call_FEE_v Decimal(10,4) COMMENT '当月通话费用与上月相比的增长比例',
    gprs_fee Decimal(18,2) COMMENT '用户当月的流量费用',
    gprs_fee_v Decimal(10,4) COMMENT '当月流量费用与上月相比的增长比例',
    tax_on_yuezu Decimal(18,2) COMMENT '用户当月实际收取的套餐费用',
    pre_tax_on_yuezu Decimal(18,2) COMMENT '用户上月实际收取的套餐费用',
    pre1_tax_on_yuezu Decimal(18,2) COMMENT '用户上上月实际收取的套餐费用',
    zhekou Decimal(18,2) COMMENT '用户当月享受的折扣或折让费用（通过系统充值）',
    pre_zhekou Decimal(18,2) COMMENT '用户上月享受的折扣或折让费用',
    pre1_zhekou Decimal(18,2) COMMENT '用户上上月享受的折扣或折让费用',
    zhekou_v Decimal(10,4) COMMENT '当月折扣折让费用占ARPU的比例',
    is_tc_free Int8 COMMENT '判断用户是否享受套餐减免优惠',
    jm_tc_sy_times Int32 COMMENT '套餐减免优惠的剩余有效期',
    tc_sy_times Int32 COMMENT '用户当前套餐的剩余有效期',
    LAM_MYTHF_FEE Decimal(18,2) COMMENT '用户当月产生的漫游费用',
    LAM_MYTHF_FEE_pre1 Decimal(18,2) COMMENT '用户上月产生的漫游费用',
    LAM_MYTHF_FEE_pre2 Decimal(18,2) COMMENT '用户上上月产生的漫游费用',
    LAM_MYTHF_FEE_v Decimal(10,4) COMMENT '当月漫游费用与上月相比的增长比例',
    plan_id_bd Int8 COMMENT '判断用户主套餐是否与上月不同',
    plan_fee Decimal(18,2) COMMENT '用户当前主套餐的价格',
    plan_fee_pre1 Decimal(18,2) COMMENT '用户上月主套餐的价格',
    plan_fee_pre2 Decimal(18,2) COMMENT '用户上上月主套餐的价格',
    tc_use_times Int32 COMMENT '用户使用最新套餐的累计时长',
    plan_fee_bd Int8 COMMENT '判断用户主套餐价格是否与上月不同',
    plan_six_num Int32 COMMENT '用户近6个月内更换套餐的次数',
    is_jd Int8 COMMENT '判断用户当月是否将套餐降档',
    is_jd_3month Int8 COMMENT '判断用户近3个月内是否将套餐降档',
    is_5gtb Int8 COMMENT '判断用户近3个月内是否办理了5G套包',
    plan_5g_mark Int8 COMMENT '判断用户是否使用5G套餐',
    arpu_momr Decimal(10,4) COMMENT '当月ARPU与上月ARPU的环比变化比例',
    pve_arpu_momr Decimal(10,4) COMMENT '上月ARPU与上上月ARPU的环比变化比例',
    gprsplan_fee Decimal(18,2) COMMENT '用户当月GPRS套餐费用',
    lam_yzf_fee_pve1 Decimal(18,2) COMMENT '用户上月套餐费用',
    lam_yzf_fee_pve2 Decimal(18,2) COMMENT '用户上上月套餐费用',
    last_gprs_billing_flows Int64 COMMENT '用户上月GPRS计费流量（单位：字节）',
    before_last_gprs_billing_flows Int64 COMMENT '用户上上月GPRS计费流量（单位：字节）',
    over_flow_3month Int64 COMMENT '用户近3个月内超出套餐的流量（单位：MB）',
    is_lower_arpu Int8 COMMENT 'ARPU低于28元',
    is_bxl_xs3 Int8 COMMENT '近3月出现超限速情况',
    is_gprs_ct_fee_3month_h Int8 COMMENT '近3月月均流量超套费用大于10元',
    is_yuyin_ct_fee_3month_h Int8 COMMENT '近3月月均语音超套费用大于10元',
    is_arpu_high Int8 COMMENT '近3月月均arpu/近3月月均主套餐费用大于等于150%',
    is_lower_arpu3 Int8 COMMENT '近3月转过低资费（28以下）',
    DUAL_CARD_USER_MARK Int8 COMMENT '0：否 1：是',
    is_llb Int8 COMMENT '判断用户当月是否订购了流量包',
    prv1_llb Int8 COMMENT '判断用户上月是否订购了流量包',
    prv2_llb Int8 COMMENT '判断用户上上月是否订购了流量包',
    llb_cnt Int32 COMMENT '用户当前生效的流量包数量',
    is_dxb Int8 COMMENT '判断用户是否订购了定向流量包（如视频、音乐等特定应用流量包）',
    llb_should_fee Decimal(18,2) COMMENT '用户当月订购流量包的总费用',
    is_ywzk Int8 COMMENT '判断用户当月是否为异网主卡用户',
    new_ywsk Int8 COMMENT '判断用户当月是否新增了异网双卡',
    prv1_new_ywsk Int8 COMMENT '判断用户上月是否新增了异网双卡',
    bwsk_new Int8 COMMENT '判断用户当月是否新增了本网双卡',
    prv1_new_bwsk Int8 COMMENT '判断用户上月是否新增了本网双卡',
    is_ywsk Int8 COMMENT '判断用户当月是否为异网双卡用户',
    is_bwsk Int8 COMMENT '判断用户当月是否为本网双卡用户',
    is_zdhy Int8 COMMENT '判断用户是否使用合约机',
    imei_online Int32 COMMENT '用户终端设备的在网时长',
    HIS_IMEI_TRACK Int32 COMMENT '用户历史平均换机周期',
    IMEI_START Date COMMENT '用户上次更换终端的时间',
    PRE_TERM_PRICE Decimal(18,2) COMMENT '用户上次终端设备的裸机价格',
    SOURCE_IMEI_LONG Int32 COMMENT '用户终端设备的IMEI对应的网龄',
    TRACK_ID String COMMENT '根据用户换机周期划分的档次（如短周期、中周期、长周期）',
    out_call_duration_m Int64 COMMENT '用户当月主叫计费通话时长',
    out_call_duration_m1 Int64 COMMENT '用户上月主叫计费通话时长',
    out_call_duration_m2 Int64 COMMENT '用户上上月主叫计费通话时长',
    out_call_duration_m3 Int64 COMMENT '用户前三月主叫计费通话时长',
    avg_call_duration_m_prv_3m Int64 COMMENT '用户近3个月平均总计费通话时长',
    avg_out_call_duration_m_3m Int64 COMMENT '用户近3个月平均主叫计费通话时长',
    avg_in_call_dura_3m Int64 COMMENT '用户近3个月平均被叫计费通话时长',
    call_dura_v Decimal(10,4) COMMENT '当月计费时长与上月相比的下降比例',
    call_counts Int32 COMMENT '用户当月的通话次数',
    avg_callcount_3m Int32 COMMENT '用户近3个月平均通话次数',
    call_counts_bd Decimal(10,4) COMMENT '用户近3个月通话次数的波动情况',
    call_counts_prv1 Int32 COMMENT '用户上月的通话次数',
    call_counts_prv2 Int32 COMMENT '用户上上月的通话次数',
    call_counts_prv3 Int32 COMMENT '用户前三月的通话次数',
    call_duration_m Int64 COMMENT '用户当月的通话时长',
    avg_callduration_3m Int64 COMMENT '用户近3个月平均通话时长',
    call_duration_m_bd Decimal(10,4) COMMENT '用户近3个月通话时长的波动情况',
    call_duration_m_prv1 Int64 COMMENT '用户上月的通话时长',
    call_duration_m_prv2 Int64 COMMENT '用户上上月的通话时长',
    call_duration_m_prv3 Int64 COMMENT '用户前三月的通话时长',
    call_duration_m_prv_v Decimal(10,4) COMMENT '当月通话时长与上月相比的增长比例',
    out_call_duration Int64 COMMENT '用户当月的主叫通话时长',
    out_call_dura_prv1 Int64 COMMENT '用户上月的主叫通话时长',
    out_call_dura_prv2 Int64 COMMENT '用户上上月的主叫通话时长',
    out_call_counts Int32 COMMENT '用户当月的主叫通话次数',
    out_call_counts1 Int32 COMMENT '用户上月的主叫通话次数',
    out_call_counts2 Int32 COMMENT '用户上上月的主叫通话次数',
    out_call_counts_v Decimal(10,4) COMMENT '当月主叫次数与上月相比的增长比例',
    in_call_duration_m Int64 COMMENT '用户当月的被叫通话时长',
    in_call_duration_m_pre1 Int64 COMMENT '用户上月的被叫通话时长',
    in_call_duration_m_v Decimal(10,4) COMMENT '当月被叫时长与上月相比的增长比例',
    in_call_counts Int32 COMMENT '用户当月的被叫通话次数',
    in_call_counts1 Int32 COMMENT '用户上月的被叫通话次数',
    in_call_counts2 Int32 COMMENT '用户上上月的被叫通话次数',
    in_call_counts_v Decimal(10,4) COMMENT '当月被叫次数与上月相比的增长比例',
    out_in_call_d_v Decimal(10,4) COMMENT '主叫与被叫通话时长的比例',
    inner_call_v Decimal(10,4) COMMENT '本网通话时长占总通话时长的比例',
    out_in_call_count_v Decimal(10,4) COMMENT '主叫通话次数占总通话次数的比例',
    callfw_counts Int32 COMMENT '用户当月的呼叫转移次数',
    callfw_counts_v Decimal(10,4) COMMENT '当月呼转次数与上月相比的增长比例',
    callfw_counts1 Int32 COMMENT '用户当月呼转至外网的次数',
    call_opp_counts1 Int32 COMMENT '用户当月通话对端号码的数量（即语言交往圈人数）',
    call_opp_counts_v Decimal(10,4) COMMENT '当月通话对端号个数与上月相比的增长比例',
    avg_call_counts_3m Int32 COMMENT '用户近3个月平均总通话次数',
    avg_out_call_counts_prv_3m Int32 COMMENT '用户近3个月平均主叫通话次数',
    avg_in_call_counts_3m Int32 COMMENT '用户近3个月平均被叫通话次数',
    out_call_counts_3bd Decimal(10,4) COMMENT '用户近3个月主叫通话次数的波动情况',
    in_call_counts_3bd Decimal(10,4) COMMENT '用户近3个月被叫通话次数的波动情况',
    CALL_OPP_OUT_COUNTS Int32 COMMENT '用户N月本网主叫交往圈人数',
    prv1_call_opp_out_counts Int32 COMMENT '用户N-1月本网主叫交往圈人数',
    prv2_call_opp_out_counts Int32 COMMENT '用户N-2月本网主叫交往圈人数',
    call_opp_in_counts Int32 COMMENT '用户N月本网被叫交往圈人数',
    prv1_call_opp_in_counts Int32 COMMENT '用户N-1月本网被叫交往圈人数',
    prv2_call_opp_in_counts Int32 COMMENT '用户N-2月本网被叫交往圈人数',
    p1_yw_call_opp_counts_momr Decimal(10,4) COMMENT '本月与上月异网交往圈人数的环比变化比例',
    p2_yw_call_opp_counts_momr Decimal(10,4) COMMENT '上月与上上月异网交往圈人数的环比变化比例',
    all_bhd Decimal(10,4) COMMENT '用户当月流量使用量占套餐流量的比例',
    dou Int64 COMMENT '用户N月的流量使用量',
    dou_bd Decimal(10,4) COMMENT '用户流量使用量的波动情况',
    dou_hb_rate Decimal(10,4) COMMENT '当月流量使用量与上月相比的增长比例',
    zero_call_days Int32 COMMENT '用户当月未进行任何通话的天数',
    tc_userd Int64 COMMENT '用户主套餐内的流量使用量',
    tc_bhd Decimal(10,4) COMMENT '用户主套餐流量使用量占套餐总量的比例',
    llb_userd Int64 COMMENT '用户订购的流量包使用量',
    llb_bhd Decimal(10,4) COMMENT '用户流量包使用量占流量包总量的比例',
    bill_gprs_userd Int64 COMMENT '用户计费流量（超出套餐部分）的使用量',
    bill_bhd Decimal(10,4) COMMENT '用户计费流量使用量占计费流量上限的比例',
    dx_userd Int64 COMMENT '用户定向流量（如视频、音乐等）的使用量',
    dx_bhd Decimal(10,4) COMMENT '用户定向流量使用量占定向流量总量的比例',
    jiezhuan_userd Int64 COMMENT '用户结转流量（上月未用完的流量）的使用量',
    jiezhuan_bhd Decimal(10,4) COMMENT '用户结转流量使用量占结转流量总量的比例',
    is_llyz Int8 COMMENT '指饱和度>90%后日均流量使用量较90%之前日均流量使用量下降幅度>50%的用户',
    liul_unlimit Int8 COMMENT '判断用户当月是否使用不限量流量套餐',
    pve1_dou Int64 COMMENT '用户N-1月的流量使用量',
    pve2_dou Int64 COMMENT '用户N-2月的流量使用量',
