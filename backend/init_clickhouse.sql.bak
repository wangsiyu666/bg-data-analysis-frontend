    signal_quality_poor Int8 COMMENT '是否MR弱覆盖',
    call_drop Int8 COMMENT '存在通话掉话',
    double_decline Int8 COMMENT '当月相比前三月DOU、ARPU均下降30% 或 当月相比去年末DOU、ARPU均下降30%',
    quasi_churn Int8 COMMENT '预销或者停机达到5天',
    account_pre_churn Int8 COMMENT '用户状态是116、126方可转变账务预销户3',
    business_pre_churn Int8 COMMENT '用户状态是3,100,103,114,115,116,126,131均可转变为营业预销:2',
    voice_use_users Int32 COMMENT '成功办理客户中产生语音的用户数',
    voice_saturation Decimal(10,4) COMMENT '套餐及语音包饱和度',
    low_call_ratio Decimal(10,4) COMMENT '成功办理客户中使用语音少于10分钟的用户占比',
    data_use_users Int32 COMMENT '成功办理客户中产生流量的用户数',
    general_data_saturation Decimal(10,4) COMMENT '套餐及通用流量包饱和度（含结转流量）',
    low_data_ratio Decimal(10,4) COMMENT '成功办理客户中使用流量少于300M 的用户占比',
    roam_type String COMMENT '漫游客户(常漫/长漫)',
    overdue_stop Int8 COMMENT '到预销户时间可先按30算，这块比交复杂，地市自己可以配置',
    double_stop Int8 COMMENT '套餐不同欠费到停机机制也不同，这块的逻辑是：信誉度没了后再欠费x元进单停，再欠费y元进；如果没有单双停机制的套餐，就是信誉度没了再欠z元就双停或者叫停机了',
    single_stop Int8 COMMENT '可以接打任意电话，双停只能拨打10086，不能接听来自86的电话（其实也意义不大了），预销户开始就彻底失连了'
) ENGINE = MergeTree ORDER BY (month)
COMMENT '用户行为特征表';